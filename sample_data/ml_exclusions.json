    },
    {
      "value": "C:\\Tools\\powershell.exe",
      "groups": [
        "HG-DevTeam"
      ]
    },
    {
      "value": "C:\\Program Files\\LegacyApp\\*",
      "applied_globally": true
    }
  ]
}