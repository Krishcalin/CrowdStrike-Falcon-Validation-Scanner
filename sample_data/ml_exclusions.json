{
  "resources": [
    {
      "value": "C:\\Windows\\Temp\\*",
      "applied_globally": true
    },
    {
      "value": "C:\\Users\\*\\AppData\\Local\\Temp\\*",
      "applied_globally": true
    },
    {
      "value": "C:\\ProgramData\\CompanyApp\\*",
      "groups": [
        "HG-Workstations"
      ]
    },
    {
      "value": "*.ps1",
      "applied_globally": true
    },
    {
      "value": "D:\\Backups\\**",
